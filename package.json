{
  "name": "eule-mcp",
  "version": "0.1.0",
  "description": "MCP server for an office assistant - E-Mail/Calendar integration, GTD tasks & resource planning",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "metaneutrons",
  "repository": {
    "type": "git",
    "url": "https://github.com/metaneutrons/eule-mcp.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.7.1",
  "bin": {
    "eule-mcp": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "config.example.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "serve": "node dist/server/index.js",
    "setup": "node dist/cli/index.js setup",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "kiro",
    "office",
    "m365",
    "outlook",
    "gtd",
    "tasks",
    "calendar",
    "email"
  ],
  "dependencies": {
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^5.5.11",
    "imapflow": "^1.3.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.0",
    "nodemailer": "^8.0.5",
    "open": "^11.0.0",
    "otpauth": "^9.5.0",
    "tsdav": "^2.1.8",
    "turndown": "^7.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/turndown": "^5.0.6",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}